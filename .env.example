DATABASE_URL="file:../.data/prisma/dev.db"

# Brain LLM provider: openai | claude | google | doubao
BRAIN_LLM_PROVIDER=openai
BRAIN_LLM_MODEL=gpt-4o-mini

# Image LLM provider: openai | google | doubao
IMAGE_LLM_PROVIDER=openai
IMAGE_LLM_MODEL=dall-e-3

# Brain LLM API keys (set the key matching BRAIN_LLM_PROVIDER)
BRAIN_OPENAI_API_KEY=
BRAIN_ANTHROPIC_API_KEY=
BRAIN_GOOGLE_API_KEY=
BRAIN_DOUBAO_API_KEY=
BRAIN_DOUBAO_BASE_URL=

# Image LLM API keys (set the key matching IMAGE_LLM_PROVIDER)
IMAGE_OPENAI_API_KEY=
IMAGE_GOOGLE_API_KEY=
IMAGE_DOUBAO_API_KEY=
IMAGE_DOUBAO_BASE_URL=

# Shared Doubao image options (used when IMAGE_LLM_PROVIDER=doubao)
DOUBAO_IMAGE_SIZE=

# Legacy shared API keys (optional fallbacks if role-specific keys are unset)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=

# --- Vector retrieval (UPG dense retrieval + chat semantic recall) ---
# Embeddings are optional: if disabled/unconfigured, retrieval falls back to TF-IDF cosine.
# EMBEDDING_ENABLED=true

# Provider: openai (API) | local (in-process ONNX via Transformers.js, no API key)
# EMBEDDING_PROVIDER=openai

# OpenAI embeddings (EMBEDDING_PROVIDER=openai)
EMBEDDING_OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_OPENAI_BASE_URL=

# Local embeddings (EMBEDDING_PROVIDER=local) — model auto-downloaded & cached on first use.
# Default model: Xenova/paraphrase-multilingual-MiniLM-L12-v2 (384-dim, multilingual).
# EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# LOCAL_EMBEDDING_CACHE_DIR=.data/models
# HF_ENDPOINT=https://hf-mirror.com   # mirror for restricted networks
# HF_HUB_OFFLINE=1   # set after first download to force fully offline

# Embedding dimension (auto-detected; override only if you change models). Must be
# stable for a deployment — changing it requires rebuilding the vector tables.
# EMBEDDING_DIM=

# Vector store backend. Auto-detected from VECTOR_DATABASE_URL/DATABASE_URL scheme
# (postgres:// -> pgvector, file:/sqlite -> sqlite-vec). Override with VECTOR_DB=pg|sqlite|off.
# VECTOR_DB=
# VECTOR_DATABASE_URL=postgres://user:pass@host:5432/db

# Enable /api/data/ proxy outside development (default: off in production)
# ENABLE_LOCAL_DATA_PROXY=true

# Legacy env vars (still supported as fallbacks)
OPENAI_MODEL=gpt-4o-mini
IMAGE_MODEL=dall-e-3
